# ─────────────────────────────────────────────────────────
# Leave VITE_API_URL empty during local development.
# Vite will proxy /api → http://localhost:5000 automatically.
#
# Set it only when deploying the frontend to Vercel/Netlify:
#   VITE_API_URL=https://your-backend.koyeb.app/api
# ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:7070/api
